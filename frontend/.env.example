# Backend URL (FastAPI + LangGraph orchestrator)
REMOTE_ACTION_URL=http://localhost:8000/copilotkit

# LLM Provider: nebius | openai | google
LLM_PROVIDER=nebius

# Nebius (default)
NEBIUS_API_KEY=your-nebius-api-key
NEBIUS_MODEL=Qwen/Qwen3-32B-fast

# OpenAI (alternative)
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o

# LangSmith (optional - for agent tracing)
# LANGSMITH_API_KEY=
# LANGCHAIN_TRACING_V2=false
# LANGCHAIN_PROJECT=dreamrag
