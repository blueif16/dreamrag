# LLM Provider: "nebius" (default) | "openai" | "google"
LLM_PROVIDER=nebius

# Nebius (default — Qwen3-32B-fast)
NEBIUS_API_KEY=your-nebius-key-here
# NEBIUS_MODEL=Qwen/Qwen3-32B-fast

# OpenAI (alternative)
# OPENAI_API_KEY=your-openai-key-here
# OPENAI_MODEL=gpt-4o

# Google (alternative)
# GOOGLE_API_KEY=your-google-key-here
# GOOGLE_MODEL=gemini-2.0-flash

# Server
FRONTEND_URL=http://localhost:3000
PORT=8000

# System prompt (optional override)
# SYSTEM_PROMPT=You are a helpful assistant.

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-supabase-service-role-key

# ── Local llama.cpp inference servers (GCP / docker compose) ─────────────────
# When LLM_PROVIDER=openai, langchain-openai's ChatOpenAI reads OPENAI_BASE_URL.
# In docker compose these are set automatically; uncomment for bare-metal dev.
# OPENAI_BASE_URL=http://localhost:8081/v1
# OPENAI_API_KEY=not-needed
# OPENAI_MODEL=qwen3.6-35b-a3b

# Embedding — qwen3-embedding-0.6b (--port 8082)
EMBED_BASE_URL=http://localhost:8082/v1
EMBED_MODEL=qwen3-embedding-0.6b
EMBED_DIM=1024
